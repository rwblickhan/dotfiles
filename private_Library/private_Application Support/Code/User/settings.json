{
  "files.autoSave": "onFocusChange",
  "editor.formatOnSave": true,
  "editor.stickyScroll.enabled": true,
  "editor.fontFamily": "'Atkinson Hyperlegible Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.lineNumbers": "relative",
  "editor.guides.bracketPairs": "active",
  "editor.codeActionsOnSave": {
    "source.fixAll.stylelint": "always"
  },
  "diffEditor.experimental.showMoves": true,
  "workbench.colorTheme": "Ayu Dark Bordered",
  "workbench.quickOpen.preserveInput": true,
  "workbench.tree.enableStickyScroll": true,
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },
  "stylelint.validate": [
    "css",
    "scss"
  ],
  "editor.gotoLocation.multipleDeclarations": "goto",
  "editor.gotoLocation.multipleDefinitions": "goto",
  "editor.gotoLocation.multipleImplementations": "goto",
  "editor.gotoLocation.multipleReferences": "goto",
  "editor.gotoLocation.multipleTypeDefinitions": "goto",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "editor.minimap.enabled": false,
  // https://practicaltypography.com/ligatures-in-programming-fonts-hell-no.html
  "editor.fontLigatures": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "files.exclude": {
    ".zig-cache": true,
    "node_modules": true,
    "zig-out": true
  },
  "git.autofetch": true,
  // Force Emmet suggestions to show up at the bottom
  "emmet.showSuggestionsAsSnippets": true,
  "editor.snippetSuggestions": "bottom",
  "rust-analyzer.check.command": "clippy",
  "git.enableSmartCommit": true,
  "security.promptForLocalFileProtocolHandling": false,
  "workbench.editor.empty.hint": "hidden",
  "editor.accessibilitySupport": "off",
  "git.openRepositoryInParentFolders": "always",
  "astro.content-intellisense": true,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": true,
  "search.useParentIgnoreFiles": true,
  "remote.SSH.remotePlatform": {
    "*.gitpod.local": "linux",
    "*.gitpod.remote": "linux"
  },
  "task.allowAutomaticTasks": "on",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  }
}